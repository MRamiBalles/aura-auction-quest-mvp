# Environment Variables for Deployment

# IMPORTANT: Never commit this file to git!
# Copy this file to .env and fill in your values

# ========================================
# Deployment Wallet
# ========================================
# Private key of the wallet that will deploy contracts
# Get from MetaMask: Account Details > Export Private Key
# WARNING: Keep this secret! Anyone with this can access your funds
PRIVATE_KEY=your_private_key_here

# ========================================
# RPC URLs
# ========================================
# Polygon Amoy Testnet RPC
AMOY_RPC_URL=https://rpc-amoy.polygon.technology/

# Polygon Mainnet RPC
POLYGON_RPC_URL=https://polygon-rpc.com/

# ========================================
# API Keys
# ========================================
# PolygonScan API Key (for contract verification)
# Get from: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ========================================
# Contract Addresses (filled after deployment)
# ========================================
AURA_TOKEN_ADDRESS=
AURA_NFT_ADDRESS=
MARKETPLACE_ADDRESS=
AUCTION_HOUSE_ADDRESS=
STAKING_ADDRESS=

# ========================================
# For Backend (.env)
# ========================================
# These will be needed by your NestJS backend
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/aura-quest
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=your_super_secure_random_secret_here_minimum_32_characters

# Blockchain config (copy from above after deployment)
RPC_URL=${POLYGON_RPC_URL}
CHAIN_ID=137
